# Queen.js Signal Ingestion Environment Configuration

# Server Configuration
PORT=3000
NODE_ENV=production

# GPG Configuration
TRUSTED_KEY_ID=AE5519579584DEF5

# Logging Configuration
LOG_LEVEL=info

# Security Configuration
# Add your GPG public key path here
# GPG_PUBLIC_KEY_PATH=/path/to/public-key.asc

# Optional: Database configuration for signal storage
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=queen_signals
# DB_USER=queen
# DB_PASSWORD=your_password

# Optional: Message Queue configuration
# QUEUE_URL=redis://localhost:6379
# QUEUE_PREFIX=queen:signals

# Optional: Metrics and monitoring
# METRICS_ENABLED=true
# METRICS_PORT=9090
